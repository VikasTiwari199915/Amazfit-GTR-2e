<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.GTR2eApp" parent="Theme.Material3.DynamicColors.DayNight.NoActionBar">
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor" >?attr/colorPrimaryVariant</item>

        <item name="colorPrimary">@color/material_dynamic_primary40</item>
        <item name="colorSecondary">@color/material_dynamic_primary50</item>
        <item name="colorPrimaryVariant">@color/material_dynamic_primary10</item>
        <item name="colorAccent">@color/material_dynamic_primary40</item>
        <item name="colorTertiary">@color/material_dynamic_secondary90</item>
        <item name="colorError">#BA1A1A</item>
        <item name="colorErrorContainer">#FFDAD6</item>
    </style>
    <style name="Theme.GTR2eApp.StoreTheme" parent="Theme.Material3.DynamicColors.Light">
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor" >?attr/colorPrimaryVariant</item>

        <item name="colorPrimary">@color/material_dynamic_primary40</item>
        <item name="colorSecondary">@color/material_dynamic_primary50</item>
        <item name="colorPrimaryVariant">@color/material_dynamic_primary10</item>
        <item name="colorAccent">@color/material_dynamic_primary40</item>
        <item name="colorTertiary">@color/material_dynamic_secondary90</item>
        <item name="colorError">#BA1A1A</item>
        <item name="colorErrorContainer">#FFDAD6</item>
    </style>
    <style name="Theme.BottomNavigationView.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">?attr/colorTertiary</item>
    </style>
    <style name="Preference.SwitchPreferenceCompat" parent="@style/Preference.SwitchPreferenceCompat.Material"
        tools:ignore="ResourceCycle">
        <item name="widgetLayout">@layout/preference_switch</item>
    </style>
</resources>